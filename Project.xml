<?xml version="1.0" encoding="utf-8"?>
<project>
	<app title="Baldi's Basics in Funkin'" file="BaldiFunkin" packageName="com.baldifunkinteam.baldifunkin" package="com.baldifunkinteam.baldifunkin" main="Main" version="0.0.1" company="BaldiFunkinTeam" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>
	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />
	<setenv name="HAXEPATH" value="./"/>

	<define name="MODS_ALLOWED" if="desktop || android" />
	<define name="HSCRIPT_ALLOWED" if="desktop || android" />
	<define name="LUA_ALLOWED" if="cpp || android" />
	<define name="VIDEOS_ALLOWED" if="cpp || android"/>
	<define name="CRASH_HANDLER" if="android" />

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="mobile" orientation="landscape" fullscreen="true" width="1280" height="720" resizable="false"/>

	<classpath name="source" />
	<assets path="assets" />

	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="linc_luajit" if="android || LUA_ALLOWED"/>
	<haxelib name="hxvlc" if="android || VIDEOS_ALLOWED"/>
	<haxelib name="extension-androidtools" if="android" />

	<section if="android">
		<config android:package="com.baldifunkinteam.baldifunkin" />
		<config android:install-location="auto" />
		<config android:target-sdk-version="29" />
		<config android:min-sdk-version="21" />
	</section>

	<android permission="android.permission.ACCESS_NETWORK_STATE"/>
	<android permission="android.permission.INTERNET"/>

	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />
</project>
    <section if="FEATURE_DEBUG_TRACY">
        <haxedef name="HXCPP_TELEMETRY"/>
        <haxedef name="HXCPP_TRACY"/>
        <haxedef name="HXCPP_TRACY_MEMORY"/>
        <haxedef name="HXCPP_TRACY_ON_DEMAND"/>
        <haxedef name="absolute-paths"/>
        <!-- <haxedef name="HXCPP_TRACY_INCLUDE_CALLSTACKS"/> -->
    </section>

	<!-- Turn on Crash Handler -->
	<haxedef name="CRASH_HANDLER" if="desktop" />

	<!--improves hscript tracing-->
	<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED"/>

	<!--Disable deprecated warnings-->
	<haxedef name='no-deprecation-warnings' />

	<!--Nicer error reporting-->
	<haxedef name="message.reporting" value="pretty" />

	<!--Enable the Flixel core recording system-->
	<!--<haxedef name="FLX_RECORD" />-->

	<!--Disable the right and middle mouse buttons-->
	<!-- <haxedef name="FLX_NO_MOUSE_ADVANCED" /> -->

	<!--Disable the native cursor API on Flash-->
	<!--<haxedef name="FLX_NO_NATIVE_CURSOR" />-->

	<!--Optimise inputs, be careful you will get null errors if you don't use conditionals in your game-->
	<!-- <haxedef name="FLX_NO_MOUSE" if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_KEYBOARD" if="mobile" /> -->
	<!-- <haxedef name="FLX_NO_TOUCH" if="desktop" /> -->
	<!--<haxedef name="FLX_NO_GAMEPAD" />-->

	<!--Disable the Flixel core sound tray-->
	<!--<haxedef name="FLX_NO_SOUND_TRAY" />-->

	<!--Disable the Flixel sound management code-->
	<!--<haxedef name="FLX_NO_SOUND_SYSTEM" />-->

	<!--Disable the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	
	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable this for Nape release builds for a serious peformance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />
	
	<!--Used for Izzy Engine's crash handler-->
	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER" />

	<!-- _________________________________ Custom _______________________________ -->

	<!--Place custom nodes like icons here (higher priority to override the HaxeFlixel icon)-->
	<assets path='art/iconOG.png' rename='icon.png' if="linux" />
	
	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />
</project>
