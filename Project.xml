<?xml version="1.0" encoding="utf-8"?>
<project>
	<app title="Baldi's Basics in Funkin'" file="BaldiFunkin" packageName="com.baldifunkinteam.baldifunkin" package="com.baldifunkinteam.baldifunkin" main="Main" version="0.0.1" company="BaldiFunkinTeam" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>
	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />
	<setenv name="HAXEPATH" value="./"/>

	<define name="MODS_ALLOWED" if="desktop || android" />
	<define name="HSCRIPT_ALLOWED" if="desktop || android" />
	<define name="LUA_ALLOWED" if="cpp || android" />
	<define name="VIDEOS_ALLOWED" if="cpp || android"/>
	<define name="CRASH_HANDLER" if="android || desktop" />

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="mobile" orientation="landscape" fullscreen="true" width="1280" height="720" resizable="false"/>

	<classpath name="source" />
	<classpath name="source/android" if="android" /> 
	
	<assets path="assets" />
	<assets path="assets/android" if="android" /> <haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="linc_luajit" if="android || LUA_ALLOWED"/>
	<haxelib name="hxvlc" if="android || VIDEOS_ALLOWED"/>
	<haxelib name="extension-androidtools" if="android" />

	<section if="android">
		<config android:package="com.baldifunkinteam.baldifunkin" />
		<config android:install-location="auto" />
		<config android:target-sdk-version="29" />
		<config android:min-sdk-version="21" />
	</section>

	<android permission="android.permission.ACCESS_NETWORK_STATE"/>
	<android permission="android.permission.INTERNET"/>

	<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED"/>
	<haxedef name='no-deprecation-warnings' />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG" unless="debug" />
	
	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER" />

	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />
</project>
